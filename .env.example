# Google Gemini API
# ⚠️ Gemini 키는 더 이상 프론트엔드에 두지 않습니다 — 백엔드(Cloud Run) 프록시 경유로만 호출합니다.
#    키는 Cloud Run 환경변수 GEMINI_API_KEY 로만 설정하세요 (cloud-run/gemini_proxy.py 참고).

# Google OAuth (Drive 동기화) — Client ID는 공개되어도 무방 (Secret은 백엔드 전용)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Cloud Run 백엔드 URL (미설정 시 코드의 기본값 사용). 자체 배포 시 본인 서버로 지정
VITE_CLOUD_RUN_BASE_URL=https://your-backend.run.app

# 포트폴리오 저장용 Google Drive 폴더 ID (미설정 시 코드의 기본값 사용)
# 참고: OAuth 스코프가 drive.file이라 앱이 생성/소유한 파일·폴더만 접근 가능합니다.
#       새로 설치하는 경우, 수동으로 만든 폴더 ID 대신 비워두면(루트 저장) 안전합니다.
VITE_DRIVE_FOLDER_ID=
